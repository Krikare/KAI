{
  "manifest_version": 3,
  "name": "KAI Context Dictionary",
  "version": "1.0",
  "description": "Select any word to see contextual meaning instantly.",
  
  "permissions": [
    "activeTab",
    "scripting"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}